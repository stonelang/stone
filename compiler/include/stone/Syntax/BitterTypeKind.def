/// BITTER_TYPE(id, parent)
///   If the type node is not abstract, its enumerator value is
///   TypeKind::id.  The node's class name is 'id##Type', and the name of
///   its base class (in the Type hierarchy) is 'parent' (including
///   the 'Type' suffix).

/// CANONICAL_BITTER_TYPE(id, parent)
///   This type is always canonical.  The default behavior is BITTER_TYPE(id, parent).

/// BUILTIN_BITTER_TYPE(id, parent)
///   This type is a builtin type. The default behavior is
///   CANONICAL_BITTER_TYPE(id, parent).

/// SUGARED_BITTER_TYPE(id, parent)
///   This type is never canonical.  It provides an efficient accessor,
///   getSinglyDesugaredType(), which removes one level of sugar.  This
///   process does not necessarily converge to the canonical type, however.
///   The default behavior is BITTER_TYPE(id, parent).
//
// If you add a new sugared type, be sure to test it in PrintAsObjC!

/// UNCHECKED_BITTER_TYPE(id, parent)
///   This type is not present in valid, type-checked programs.
///   The default behavior is BITTER_TYPE(id, parent).

/// ARTIFICIAL_BITTER_TYPE(id, parent)
///   This type is not part of the user-facing type system. It may be
///   used freely in SIL, and it may appear as the type of a
///   declaration in the AST (due to e.g. the application of the
///   [weak] attribute), but it cannot be written directly in normal
///   programs and it cannot be the type of an expression.
///   The default behavior is BITTER_TYPE(id, parent).

/// SINGLETON_BITTER_TYPE(SHORT_ID, id)
///   This type is a singleton, i.e. there is exactly one instance of
///   it, which can be found as ASTContext.The#SHORT_ID#Type.
///   This is only expanded if SINGLETON_BITTER_TYPE is defined, and in this
///   case no other macros are expanded.

#ifndef CANONICAL_BITTER_TYPE
#define CANONICAL_BITTER_TYPE(id, parent) BITTER_TYPE(id, parent)
#endif

#ifndef BUILTIN_BITTER_TYPE
#define BUILTIN_BITTER_TYPE(id, parent) CANONICAL_BITTER_TYPE(id, parent)
#endif

#ifndef UNCHECKED_BITTER_TYPE
#define UNCHECKED_BITTER_TYPE(id, parent) BITTER_TYPE(id, parent)
#endif

#ifndef ARTIFICIAL_BITTER_TYPE
#define ARTIFICIAL_BITTER_TYPE(id, parent) BITTER_TYPE(id, parent)
#endif

/// Most metaprograms do not care about abstract types, so the default
/// is to ignore them.
#ifndef ABSTRACT_BITTER_TYPE
#define ABSTRACT_BITTER_TYPE(Id, Parent)
#endif
/// A convenience for determining the range of types.  These will always
/// appear immediately after the last member.
#ifndef BITTER_TYPE_RANGE
#define BITTER_TYPE_RANGE(Id, First, Last)
#endif

#ifndef   BITTER_TYPE_LAST_TYPE
#define   BITTER_TYPE_LAST_TYPE(Id)
#endif

BITTER_TYPE(Error, Type)
BITTER_TYPE(LValue, Type)
BITTER_TYPE(RValue, Type)
BITTER_TYPE(Tuple, Type)

ABSTRACT_BITTER_TYPE(Builtin, Type)
  ABSTRACT_BITTER_TYPE(AbstractNumber,  BuiltinType)
    BUILTIN_BITTER_TYPE(Integer,         AbstractNumberType)
    BUILTIN_BITTER_TYPE(UInteger,        AbstractNumberType)
    BUILTIN_BITTER_TYPE(Float,           AbstractNumberType)
    BUILTIN_BITTER_TYPE(Void,            AbstractNumberType)
    BUILTIN_BITTER_TYPE(Complex,         AbstractNumberType)
    BUILTIN_BITTER_TYPE(Imaginary,       AbstractNumberType)
    BITTER_TYPE_RANGE(AbstractNumber, Integer, Imaginary) 
  BUILTIN_BITTER_TYPE(Null, BuiltinType)
BITTER_TYPE_RANGE(Builtin, Integer, Null) 

ABSTRACT_BITTER_TYPE(AbstractPointer, Type)
  BITTER_TYPE(Pointer, AbstractPointerType)
  BITTER_TYPE(BlockPointer, AbstractPointerType)
  BITTER_TYPE(MemberPointer, AbstractPointerType)
BITTER_TYPE_RANGE(AbstractPointer, Pointer, MemberPointer)

// ABSTRACT_BITTER_TYPE(Deduced, Type)
//   BITTER_TYPE(Auto, DeducedType)
// BITTER_TYPE_RANGE(Deduced, Auto)

ABSTRACT_BITTER_TYPE(AbstractFunction, Type)
  BITTER_TYPE(Function, AbstractFunctionType)
  BITTER_TYPE(GenericFunction, FunctionType)
BITTER_TYPE_RANGE(AbstractFunction, Function, GenericFunction)

ABSTRACT_BITTER_TYPE(Nominal, Type)
      BITTER_TYPE(Enum, NominalType)
      BITTER_TYPE(Struct, NominalType)
      BITTER_TYPE(Interface, NominalType)
BITTER_TYPE_RANGE(Nominal, Enum, Interface)
LAST_BITTER_TYPE(Interface)

#undef BITTER_TYPE_RANGE
#undef ABSTRACT_SUGARED_BITTER_TYPE
#undef ABSTRACT_BITTER_TYPE
#undef UNCHECKED_BITTER_TYPE
#undef ARTIFICIAL_BITTER_TYPE
#undef BUILTIN_BITTER_TYPE
#undef CANONICAL_BITTER_TYPE
#undef BITTER_TYPE
#undef LAST_BITTER_TYPE
