//===----------------------------------------------------------------------===//
//
// This file defines macros used for macro-metaprogramming with compiler-known
// identifiers.
//
//===----------------------------------------------------------------------===//

#ifndef LANG_IDENTIFIER_WITH_NAME
#  error Must define LANG_IDENTIFIER_WITH_NAME(Name, IdStr) before including this x-macro file
#endif

#define LANG_IDENTIFIER(name) LANG_IDENTIFIER_WITH_NAME(name, #name)
#define LANG_IDENTIFIER_(name) LANG_IDENTIFIER_WITH_NAME(name, "_" #name)

LANG_IDENTIFIER(Main)

#undef LANG_IDENTIFIER
#undef LANG_IDENTIFIER_
#undef LANG_IDENTIFIER_WITH_NAME
