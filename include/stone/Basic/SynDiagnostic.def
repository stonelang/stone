#define DEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"



// LEXER

WARNING(lex_warn_null_character,none,
        "null character embedded in middle of file", ())

// PARSER  
NOTE(parser_note_opening_brace,none,
     "to match this opening '{'", ())
NOTE(parser_note_opening_bracket,none,
     "to match this opening '['", ())
NOTE(parser_note_opening_paren,none,
     "to match this opening '('", ())
NOTE(parser_note_opening_angle,none,
     "to match this opening '<'", ())


// PARSER


// CHECKER 

#define UNDEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"
