#define DEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"

ERROR(invalid_diagnostic,none,
      "INTERNAL ERROR: this diagnostic should not be produced", ())

ERROR(err_no_input_files, none, "no input files", ())

ERROR(err_unknown_arg, none, "unknown argument:", (diag::LLVMStrArgument))


ERROR(err_unable_to_open_output, none, "could not open output", (diag::LLVMStrArgument, diag::LLVMStrArgument))

ERROR(err_unable_to_open_buffer_for_file, none, "could not open file buffer for", (diag::LLVMStrArgument))

#define UNDEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"
