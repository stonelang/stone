#define DEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"

ERROR(err_no_compile_args, none,
      "no arguments provided to '-compile'", ())

ERROR(err_no_compile_mode, none, "no compile mode", ())

ERROR(err_unable_to_open_output, none, "could not open output", (diag::LLVMStrArgument, diag::LLVMStrArgument))

ERROR(err_unable_to_open_filebuffer, none, "could not open file buffer for", (diag::LLVMStrArgument))

#define UNDEFINE_DIAGNOSTIC_MACROS
#include "DefineDiagnostic.h"
