#ifndef BASE_STMT
#define BASE_STMT(Id, Parent)
#endif

/// A subclass of LabeledStmt.  Forwards to STMT by default.
#ifndef LBL_STMT
#define LBL_STMT(Id, Parent) STMT(Id, Parent)
#endif

/// A subclass of LabeledStmt.  Forwards to STMT by default.
#ifndef EXPR_STMT
#define EXPR_STMT(Id, Parent) STMT(Id, Parent)
#endif

/// A literal expression node represents a literal value, such as a number,
/// boolean, string, etc.
///
/// By default, these are treated like any other expression.
#ifndef LIT_EXPR_STMT
#define LIT_EXPR_STMT(Id, Parent) EXPR_STMT(Id, Parent)
#endif


/// A expression node with a DeclContext. For example: closures.
///
/// By default, these are treated like any other expression.
#ifndef CTX_EXPR_STMT
#define CTX_EXPR_STMT(Id, Parent) EXPR_STMT(Id, Parent)
#endif


/// A convenience for determining the range of statements.  These will always
/// appear immediately after the last member.
#ifndef STMT_RANGE
#define STMT_RANGE(Id, First, Last)
#endif

#ifndef LAST_STMT
#define LAST_STMT(Id)
#endif

STMT(Brace, Stmt)
STMT(Return, Stmt)
STMT(Block, Stmt)
STMT(Yield, Stmt)
STMT(Defer, Stmt)
STMT(Case, Stmt)
STMT(Break, Stmt)
STMT(Continue, Stmt)
BASE_STMT(ValueStmt, Stmt)
  BASE_STMT(Labeled, ValueStmt)
    BASE_STMT(LabeledConditional, LabeledStmt)
      LBL_STMT(If, LabeledConditionalStmt)
      LBL_STMT(While, LabeledConditionalStmt)
      STMT_RANGE(LabeledConditional, If, While)
    LBL_STMT(Do, LabeledStmt)
    LBL_STMT(Loop, LabeledStmt)
    LBL_STMT(ForEach, LabeledStmt)
    LBL_STMT(Switch, LabeledStmt)
    STMT_RANGE(Labeled, If, Switch)
    // Expressions 
  BASE_STMT(Expr, ValueStmt)
    EXPR_STMT(New,  Expr)
    EXPR_STMT(Delete,  Expr)
    EXPR_STMT(This, Expr)
    EXPR_STMT(Call, Expr)
    EXPR_STMT(Paren, Expr)
    BASE_STMT(Literal, Expr)
      LIT_EXPR_STMT(NullLiteral, LiteralExpr)
      BASE_STMT(BuiltinLiteral, LiteralExpr)
          LIT_EXPR_STMT(BooleanLiteral, BuiltinLiteralExpr)
          LIT_EXPR_STMT(StringLiteral, BuiltinLiteralExpr)
          BASE_STMT(NumberLiteral, BuiltinLiteralExpr)
            LIT_EXPR_STMT(IntegerLiteral, NumberLiteralExpr)
            LIT_EXPR_STMT(FloatLiteral, NumberLiteralExpr)
  BASE_STMT(AbstractClosure, Expr)
    CTX_EXPR_STMT(Closure, AbstractClosureExpr)

STMT(Next, Stmt)
LAST_STMT(Next)

#undef STMT_RANGE
#undef LBL_STMT
#undef BASE_STMT
#undef LIT_EXPR_STMT
#undef CTX_EXPR_STMT
#undef EXPR_STMT
#undef STMT
#undef LAST_STMT