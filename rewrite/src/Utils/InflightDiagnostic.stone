
space Stone.Utils {

	public struct InFlightDiagnostic {
		private ref CodeFixer fixer; 
  }

	public InFlightDiagnostic::this() {
	}
	public InFlightDiagnostic::~this() {
	}
	public fun InFlightDiagnostic::Flush() -> void {
	}
