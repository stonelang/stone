

// project/Stone/Physics/ParticleProfile.stone 
space Stone::Physics::ParticleProfile {

	struct ParticleProfile {
		public float32 mass; 
		public string name; 
	}
	public interface Particle {
		fun Fire() -> auto;  
	}	
	public struct Proton : Particle {
		ParticleProfile* profile = null;
	}

	public Proton::this(const ParticleProfile* profile) {
			this.profile = profile; 
	 }
	public Proton::~this() {
		free profile;
	}
	public fun Proton::GetProfile() -> ParticleProfile* {
		return profile;  
	}
	public fun Proton::Fire() -> auto {
		int* result = null;
		if(profile.mass > 10.00) {
		}
		return true;
	}
}


