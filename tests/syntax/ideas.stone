
space Physics.QM {

	public struct Particle {
		public bool fired = false; 
	}
	public any<T> interface Accelerator {
		fun Fire(const Particle* p) -> bool;
	}
	public struct LinearAccelerator : Accelerator<LinearAccelerator> {
		private string maker; 
		private Detector* detector = null; 
	}
	public default LinearAccelerator::LinearAccelerator() 
		: LinearAcceleartor("default") {
	}

	public LinearAccelerator::LinearAccelerator(string maker) {
		detector = new Detector();
	}

	public LinearAccelerator::~LinearAccelerator() {
		if(detector) {
			delete detector;
		}
	}	
	public fun LinearAcellerator::Fire(const Particle* p) -> bool {
		p.fired = true; 
		return true; 
	}

	fun Main() -> i32 {

		auto p = new Particle();
		auto a = new LinearAcceleartor(); 
		a.Fire(a);

		delete p; 
		delete a;
	}

}

space Physics.QM {


