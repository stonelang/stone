
space Physics.QM {
	public struct Particle {
		public bool fired = false; 
	}
	public any<T> interface Accelerator {
		fun Fire(const Particle* p) -> bool;
	}
	public struct LinearAccelerator : Accelerator<LinearAccelerator> {
		local string maker; 
		own Detector* detector = null;
	}

	LinearAcceleartor::this() : this("none") {
			detector = new Detector(); 
	}
	LinearAcceleartor::this(string maker) {
	}
	LinearAcceleartor:::~this() {	
		if(detector){
			delete detector;
		}
	}
	public fun LinearAcellerator::Fire(const Particle* p) -> bool {
		p.fired = true; 
		return true; 
	}
	use max = fun(int first, int second) -> int;
	fun Main() -> i32 {

		Particle* p = new Particle();
		auto a = new LinearAcceleartor(); 
		a.Fire(a);

		delete p; 
		delete a;
		// auto Fire = fun() -> Particle* {
		// 	auto p = new Particle();
		// 	p.Fire(); 
		// }

	}

}

