

space Physics {

	public interface Accelerator {
		fun Fire(const Particle* particle) -> bool;
	}

	public struct LinearAccelerator : Accelerator {
	}
	public fun LinearAccelerator::LinearAccelerator() {
	}
	public fun LinearAccelerator::~LinearAccelerator() {

	}
