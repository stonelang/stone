
import System.Core; 

import Stone.Tests.Behavior.Modules; 

// Main module 
fun Main() -> int {

	Physics.LinearAcceleartor* la = new Physics.LinearAcceleartor();
	physics.Electron* electron = new Physics.Electron();

	defer{
		delete electron;
		delete la; 
	}
	la.Fire(electron);
}


